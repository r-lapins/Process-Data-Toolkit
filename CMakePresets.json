{
  "version": 3,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 25
  },
  "configurePresets": [
    {
      "name": "debug",
      "displayName": "Debug",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/debug",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "PDT_ENABLE_SANITIZERS": "ON"
      }
    },
    {
      "name": "release",
      "displayName": "Release",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/release",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "PDT_ENABLE_SANITIZERS": "OFF"
      }
    },
    {
      "name": "debug-nosan",
      "displayName": "Debug (no sanitizers)",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/debug-nosan",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "PDT_ENABLE_SANITIZERS": "OFF"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "debug",
      "configurePreset": "debug"
    },
    {
      "name": "release",
      "configurePreset": "release"
    },
    {
      "name": "debug-nosan",
      "configurePreset": "debug-nosan"
    }
  ],
  "testPresets": [
    {
      "name": "debug",
      "configurePreset": "debug"
    },
    {
      "name": "debug-nosan",
      "configurePreset": "debug-nosan"
    }
  ]
}
